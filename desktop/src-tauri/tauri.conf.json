{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Jupiter",
  "version": "0.89.2",
  "identifier": "dev.jupiter.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Jupiter",
        "width": 1024,
        "height": 720,
        "minWidth": 480,
        "minHeight": 320,
        "center": true,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "backgroundColor": "#0b0b0b"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: https://asset.localhost; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://api.deepseek.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../dist": "dist",
      "../../data": "data"
    },
    "createUpdaterArtifacts": false,
    "windows": {
      "nsis": {
        "languages": [
          "English",
          "SimpChinese"
        ],
        "customLanguageFiles": {
          "English": "nsis/English.nsh",
          "SimpChinese": "nsis/SimpChinese.nsh"
        }
      }
    }
  }
}
